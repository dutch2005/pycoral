#!/usr/bin/make -f

export TF_PYTHON_VERSION=3.12

%:
	dh $@ --with python3

override_dh_auto_build:
	# Build the native extension using Bazel
	bazel build --compilation_mode=opt //src:_pywrap_coral.so
	# Setup the python package structure
	mkdir -p pycoral/pybind
	cp bazel-bin/src/_pywrap_coral.so pycoral/pybind/
	touch pycoral/pybind/__init__.py
	# Build the wheel or just prepare for dh_python3
	python3 setup.py build

override_dh_auto_install:
	python3 setup.py install --root=$(CURDIR)/debian/python3-coral --install-layout=deb

override_dh_clean:
	dh_clean
	bazel clean
