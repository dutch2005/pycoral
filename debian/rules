#!/usr/bin/make -f

export TF_PYTHON_VERSION=3.12

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_build:
	# Use the vendor_deps directory prepared by the GitHub Action
	bazel build //pycoral:wheel \
		--distdir=./vendor_deps \
		--nohome_rc \
		--nosystem_rc

override_dh_auto_install:
	mkdir -p debian/python3-pycoral/usr/lib/python3/dist-packages/
	unzip bazel-bin/pycoral/*.whl -d debian/python3-pycoral/usr/lib/python3/dist-packages/
	# Clean up metadata
	rm -rf debian/python3-pycoral/usr/lib/python3/dist-packages/*.dist-info
